<footer class="cyber-footer">
  <div class="footer-container">
    <!-- Decorative -->
    <div class="footer-deco">
      <div class="footer-line-left"></div>
      <span class="footer-diamond">◆</span>
      <div class="footer-line-right"></div>
    </div>

    <!-- Content -->
    <div class="footer-content">
      <p class="footer-tagline"><%= theme.footer %></p>
      <p class="footer-copyright">
        <span class="footer-year">© <%= date(new Date(), 'YYYY') %></span>
        <span class="footer-name"><%= config.title %></span>
      </p>
      <p class="footer-powered">
        POWERED BY <a href="https://hexo.io" target="_blank">HEXO</a>
        <span class="footer-sep">|</span>
        THEME: <span class="footer-theme-name">EDGERUNNERS</span>
      </p>
    </div>

    <!-- Rebecca Quote -->
    <div class="footer-quote">
      <p class="quote-text" id="footerQuote">"I won't let anyone else I care about die."</p>
      <p class="quote-author">— REBECCA, CYBERPUNK: EDGERUNNERS</p>
    </div>
  </div>
</footer>
