<div class="tag-container">
  <div class="page-header cyber-card">
    <h1 class="page-title">
      <span class="page-title-icon">#</span>
      标签: <%= page.tag %>
    </h1>
    <p class="page-desc">找到 <%= page.posts.length %> 篇相关文章</p>
  </div>

  <div class="archive-list">
    <% page.posts.sort('date', -1).forEach(function(post) { %>
      <article class="archive-item">
        <div class="archive-item-date">
          <span class="archive-month"><%= date(post.date, 'MM') %></span>
          <span class="archive-day"><%= date(post.date, 'DD') %></span>
        </div>
        <div class="archive-item-content">
          <h3 class="archive-item-title">
            <a href="<%- url_for(post.path) %>"><%= post.title %></a>
          </h3>
        </div>
      </article>
    <% }) %>
  </div>
</div>
