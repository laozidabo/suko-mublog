<div class="music-container">
  <div class="page-header cyber-card">
    <h1 class="page-title">
      <span class="page-title-icon">♫</span>
      Night City Radio
    </h1>
    <p class="page-desc">点一首歌，让 Night City 的霓虹灯为你闪烁</p>
  </div>

  <!-- Full Player -->
  <div class="music-player-full cyber-card">
    <div class="full-player-visual">
      <canvas id="visualizerCanvas" width="600" height="120"></canvas>
    </div>
    <div class="full-player-info">
      <span class="full-label">NOW PLAYING</span>
      <h3 class="full-title" id="fullTitle">等待点歌...</h3>
      <p class="full-artist" id="fullArtist">Night City Radio</p>
    </div>
    <div class="full-player-controls">
      <button class="full-ctrl" id="fullPrev" title="上一首">⏮</button>
      <button class="full-ctrl full-play" id="fullPlay" title="播放/暂停">▶</button>
      <button class="full-ctrl" id="fullNext" title="下一首">⏭</button>
    </div>
    <div class="full-player-progress">
      <div class="full-progress-bar" id="fullProgressBar">
        <div class="full-progress-fill" id="fullProgressFill"></div>
      </div>
      <div class="full-time">
        <span id="fullCurrentTime">0:00</span>
        <span id="fullDuration">0:00</span>
      </div>
    </div>
    <div class="full-volume">
      <span class="volume-icon">🔊</span>
      <input type="range" class="volume-slider" id="volumeSlider" min="0" max="1" step="0.01" value="0.8">
    </div>
  </div>

  <!-- Playlist -->
  <div class="playlist-section cyber-card">
    <h2 class="playlist-title">
      <span class="section-bracket">[</span>
      播放列表
      <span class="section-bracket">]</span>
    </h2>
    <div class="playlist" id="playlistItems">
      <div class="playlist-empty">播放列表为空，在下方点首歌吧</div>
    </div>
  </div>

  <!-- Song Request -->
  <div class="song-request cyber-card">
    <h2 class="request-title">
      <span class="section-bracket">[</span>
      点歌
      <span class="section-bracket">]</span>
    </h2>
    <p class="request-desc">输入歌曲信息，添加到播放列表</p>
    <form class="request-form" id="songRequestForm">
      <div class="request-fields">
        <input type="text" class="cyber-input" id="requestTitle" placeholder="歌曲名" required>
        <input type="text" class="cyber-input" id="requestArtist" placeholder="歌手名">
        <input type="url" class="cyber-input" id="requestUrl" placeholder="音频 URL (mp3/ogg/wav)" required>
      </div>
      <button type="submit" class="cyber-btn primary">添加到播放列表</button>
      <p class="request-status" id="requestStatus"></p>
    </form>
    <div class="request-tips">
      <p class="tip-title">💡 如何获取音频 URL？</p>
      <ul class="tip-list">
        <li>上传 mp3 文件到公开网盘，获取直链</li>
        <li>使用免费音乐托管服务</li>
        <li>链接需以 .mp3 / .ogg / .wav 结尾</li>
      </ul>
    </div>
  </div>
</div>
