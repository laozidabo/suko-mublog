<div class="photos-container">
  <div class="page-header cyber-card">
    <h1 class="page-title">
      <span class="page-title-icon">📷</span>
      图片墙
    </h1>
    <p class="page-desc">记忆碎片 — 凝固的瞬间</p>
  </div>

  <div class="photos-grid" id="photosGrid">
    <!-- Load photos from source/photos/ directory -->
    <div class="photo-item cyber-card">
      <div class="photo-placeholder">
        <span class="photo-icon">📷</span>
        <p>将图片放入 <code>source/photos/</code> 目录即可展示</p>
      </div>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" id="lightboxClose">✕</button>
    <img src="" alt="" class="lightbox-img" id="lightboxImg">
    <div class="lightbox-nav">
      <button class="lightbox-prev" id="lightboxPrev">←</button>
      <button class="lightbox-next" id="lightboxNext">→</button>
    </div>
  </div>
</div>
