<div class="about-container">
  <div class="about-header cyber-card">
    <div class="about-avatar-section">
      <div class="about-avatar">
        <img src="/images/avatar.svg" alt="Avatar">
      </div>
      <div class="about-intro">
        <h1 class="about-name" data-text="<%= config.author %>"><%= config.author %></h1>
        <p class="about-tagline">NETRUNNER // DEVELOPER // EDGERUNNER</p>
        <div class="about-status">
          <span class="status-dot online"></span>
          <span class="status-text">STATUS: ONLINE</span>
        </div>
      </div>
    </div>
  </div>

  <div class="about-content">
    <!-- Bio Section -->
    <section class="about-section cyber-card">
      <h2 class="about-section-title">
        <span class="section-bracket">[</span>
        个人简介
        <span class="section-bracket">]</span>
      </h2>
      <div class="about-bio">
        <p>欢迎来到我的赛博空间。这里是我的数字领地，记录着我的代码、想法和创造。</p>
        <p>在这个充满 chrome 和 neon 的世界里，我用键盘作为我的武器，代码作为我的子弹。</p>
      </div>
    </section>

    <!-- Skills Section -->
    <section class="about-section cyber-card">
      <h2 class="about-section-title">
        <span class="section-bracket">[</span>
        技能面板
        <span class="section-bracket">]</span>
      </h2>
      <div class="skills-grid">
        <div class="skill-item">
          <div class="skill-header">
            <span class="skill-name">前端开发</span>
            <span class="skill-level">LV.85</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style="width: 85%"></div>
          </div>
        </div>
        <div class="skill-item">
          <div class="skill-header">
            <span class="skill-name">后端开发</span>
            <span class="skill-level">LV.75</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style="width: 75%"></div>
          </div>
        </div>
        <div class="skill-item">
          <div class="skill-header">
            <span class="skill-name">网络安全</span>
            <span class="skill-level">LV.60</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style="width: 60%"></div>
          </div>
        </div>
        <div class="skill-item">
          <div class="skill-header">
            <span class="skill-name">系统运维</span>
            <span class="skill-level">LV.70</span>
          </div>
          <div class="skill-bar">
            <div class="skill-fill" style="width: 70%"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Cyberware Section (Fun) -->
    <section class="about-section cyber-card">
      <h2 class="about-section-title">
        <span class="section-bracket">[</span>
        义体改造
        <span class="section-bracket">]</span>
      </h2>
      <div class="cyberware-grid">
        <div class="cyberware-item">
          <div class="cyberware-icon">⌨</div>
          <div class="cyberware-name">机械键盘</div>
          <div class="cyberware-desc">+50 打字速度</div>
        </div>
        <div class="cyberware-item">
          <div class="cyberware-icon">🖥</div>
          <div class="cyberware-name">多显示器</div>
          <div class="cyberware-desc">+30 工作效率</div>
        </div>
        <div class="cyberware-item">
          <div class="cyberware-icon">☕</div>
          <div class="cyberware-name">咖啡因植入</div>
          <div class="cyberware-desc">+100 持续专注</div>
        </div>
        <div class="cyberware-item">
          <div class="cyberware-icon">🎧</div>
          <div class="cyberware-name">降噪耳机</div>
          <div class="cyberware-desc">+20 沉浸度</div>
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section class="about-section cyber-card">
      <h2 class="about-section-title">
        <span class="section-bracket">[</span>
        联系方式
        <span class="section-bracket">]</span>
      </h2>
      <div class="contact-links">
        <% if (theme.social.github) { %>
          <a href="<%= theme.social.github %>" class="contact-item" target="_blank">
            <span class="contact-icon">GH</span>
            <span class="contact-text">GitHub</span>
          </a>
        <% } %>
        <a href="mailto:<%= config.email %>" class="contact-item">
          <span class="contact-icon">@</span>
          <span class="contact-text">Email</span>
        </a>
      </div>
    </section>
  </div>
</div>
