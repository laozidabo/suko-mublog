<!-- Weather Widget -->
<div class="weather-widget" id="weatherWidget">
  <button class="weather-toggle" id="weatherToggle" title="天气">
    <span class="weather-toggle-icon">☁</span>
  </button>
  <div class="weather-panel" id="weatherPanel">
    <div class="weather-header">
      <span class="weather-title">天气实况</span>
      <button class="weather-close" id="weatherClose">✕</button>
    </div>
    <div class="weather-content" id="weatherContent">
      <div class="weather-loading">加载中...</div>
    </div>
    <div class="weather-clothing" id="weatherClothing">
      <h4 class="clothing-title">👗 穿衣建议</h4>
      <div class="clothing-content" id="clothingContent">加载中...</div>
    </div>
  </div>
</div>
